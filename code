<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Double JJ Mock Ropes</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    line-height: 1.6;
    background: #f5f5f0;
    color: #222;
}

header {
    background: #1f3d1f;
    color: white;
    text-align: center;
    padding: 40px 20px;
}

header h1 {
    font-size: 3rem;
}

header p {
    margin-top: 10px;
    font-size: 1.2rem;
}

.btn {
    display: inline-block;
    background: #8b5a2b;
    color: white;
    padding: 12px 25px;
    text-decoration: none;
    border-radius: 5px;
    margin-top: 15px;
}

section {
    padding: 50px 20px;
    max-width: 1200px;
    margin: auto;
}

.products {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
    gap: 20px;
}

.product {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,0,0,.1);
    text-align: center;
}

.product img {
    width: 100%;
    border-radius: 8px;
}

.product h3 {
    margin: 15px 0;
}

footer {
    background: #1f3d1f;
    color: white;
    text-align: center;
    padding: 25px;
}

.about {
    background: #e8e5dc;
    border-radius: 10px;
}

.contact {
    text-align: center;
}
</style>
</head>

<body>

<header>
    <h1>Double JJ Mock Ropes</h1>
    <p>Built By Hunters. Trusted In The Field.</p>
    <a href="#products" class="btn">Shop Products</a>
</header>

<section class="about">
    <h2>About Us</h2>
    <br>
    <p>
        Double JJ Mock Ropes is a family-owned hunting brand dedicated to
        providing quality mock ropes, hunting gear, hats, and apparel for
        outdoorsmen who take their hunting seriously.
    </p>
</section>

<section id="products">
    <h2>Featured Products</h2>
    <br>

    <div class="products">

        <div class="product">
            <img src="images/mockrope.jpg" alt="Mock Rope">
            <h3>Premium Mock Rope</h3>
            <p>Designed to create realistic mock scrapes and attract deer.</p>
            <p><strong>$24.99</strong></p>
        </div>

        <div class="product">
            <img src="images/hat.jpg" alt="Hat">
            <h3>Double JJ Hat</h3>
            <p>Comfortable everyday hunting hat featuring our logo.</p>
            <p><strong>$19.99</strong></p>
        </div>

        <div class="product">
            <img src="images/shirt.jpg" alt="Shirt">
            <h3>Double JJ T-Shirt</h3>
            <p>Show your support for the brand on and off the field.</p>
            <p><strong>$24.99</strong></p>
        </div>

    </div>
</section>

<section class="contact">
    <h2>Contact Us</h2>
    <br>
    <p>Email: info@doublejjmockropes.com</p>
    <p>Local Pickup Available</p>
    <p>Nationwide Shipping</p>
</section>

<footer>
    <p>© 2026 Double JJ Mock Ropes. All Rights Reserved.</p>
</footer>

</body>
</html>